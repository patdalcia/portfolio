---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Form from '../components/widgets/Form.astro';
import TextHero from '../components/widgets/TextHero.astro';
---

<Layout title='Hire Me'>
    <main>
        <Navigation
        firstLink='Home'
        secondLink='test'
        buttonLink='test'
        />
        <TextHero >
            <Fragment slot="title">
				Wanna work together<span class="hidden xl:inline">welcome to my site, </span>
				<span class="text-red-400">?</span>
			</Fragment>
			<Fragment slot="subtitle">
				<span class="hidden sm:inline">
				  <span class="font-semibold">I</span> spend a lot of time on my computer, trying to make cool things. Sometimes I succeed.</span
				>
				<span class="block mb-1 sm:hidden font-bold dark:text-white/75 text-black/50">I spend a lot of time on my computer</span>
			</Fragment>
        </TextHero>
        <Form/>
    </main>

</Layout>